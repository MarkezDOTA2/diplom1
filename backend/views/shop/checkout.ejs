<%- include('../partials/header', {
  title: 'Оформление заказа',
  breadcrumbs: [{ label: 'Корзина', url: '/cart' }, { label: 'Оформление заказа', url: '/checkout' }]
}) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<main>
  <div class="container">
    <h1 style="font-size:22px;font-weight:700;margin-top:28px;margin-bottom:12px;">Оформление заказа</h1>
    <div class="checkout-layout">

      <!-- Форма -->
      <div>

        <!-- Контакты -->
        <div class="checkout-section">
          <h3><i class="fas fa-user" style="color:var(--primary)"></i> Контактные данные</h3>
          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label">ФИО *</label>
              <input class="form-control" type="text" id="customerName"
                placeholder="Иванов Иван Иванович" maxlength="42" required
                value="<%= typeof profile !== 'undefined' ? (profile.username || '') : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label">Телефон *</label>
              <input class="form-control" type="tel" id="phone"
                placeholder="+7 (999) 000-00-00" maxlength="18" autocomplete="tel" required
                value="<%= typeof profile !== 'undefined' ? (profile.phone || '') : '' %>">
            </div>
          </div>
        </div>

        <!-- Адрес -->
        <div class="checkout-section">
          <h3><i class="fas fa-map-marker-alt" style="color:var(--primary)"></i> Адрес доставки</h3>

          <!-- Переключатель -->
          <div class="payment-methods" style="margin-bottom:16px;">
            <div class="payment-option selected" id="dopt-pickup" onclick="setDelivMode('pickup')">
              <i class="fas fa-store"></i>
              <span>Самовывоз</span>
            </div>
            <div class="payment-option" id="dopt-courier" onclick="setDelivMode('courier')">
              <i class="fas fa-motorcycle"></i>
              <span>Доставка курьером</span>
            </div>
          </div>

          <!-- Самовывоз: адрес магазина -->
          <div id="pickup-block">
            <div style="display:flex;align-items:flex-start;gap:14px;padding:16px 18px;background:#f0fafa;border-radius:12px;border:1px solid #b8e4e0;">
              <i class="fas fa-map-marker-alt" style="color:var(--primary);font-size:20px;margin-top:2px;flex-shrink:0;"></i>
              <div>
                <div style="font-weight:600;font-size:15px;margin-bottom:4px;">Пункт выдачи</div>
                <div style="font-size:14px;color:var(--text-muted);">г. Ангарск, ул. Примерная, 123</div>
                <div style="font-size:13px;color:var(--primary);margin-top:5px;"><i class="fas fa-clock"></i> Ежедневно 10:00–21:00</div>
              </div>
            </div>
          </div>

          <!-- Доставка курьером: карта + поля -->
          <div id="courier-block" style="display:none;">
            <div id="delivery-map" style="height:300px;border-radius:12px;overflow:hidden;border:1px solid var(--border);"></div>
            <p id="map-hint" style="font-size:12px;color:var(--text-muted);margin:8px 0 14px;">
              <i class="fas fa-hand-pointer"></i> Нажмите на карту, чтобы указать адрес доставки
            </p>
            <div id="street-display" style="display:none;padding:10px 14px;background:#f0fafa;border-radius:8px;border:1px solid #b8e4e0;font-size:13px;margin-bottom:14px;">
              <i class="fas fa-map-marker-alt" style="color:var(--primary);margin-right:6px;"></i>
              <span id="street-text"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
              <div class="form-group" style="margin:0;">
                <label class="form-label">Дом *</label>
                <input class="form-control" type="text" id="addr-house" placeholder="Номер дома" maxlength="4">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label">Квартира</label>
                <input class="form-control" type="text" id="addr-apt" placeholder="Номер" maxlength="4">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label">Этаж</label>
                <input class="form-control" type="text" id="addr-floor" placeholder="Этаж" maxlength="4">
              </div>
            </div>
          </div>
        </div>

        <!-- Способ оплаты -->
        <div class="checkout-section">
          <h3><i class="fas fa-credit-card" style="color:var(--primary)"></i> Способ оплаты</h3>
          <div class="payment-methods">
            <div class="payment-option selected" onclick="selectPayment('cash', this)">
              <i class="fas fa-money-bill-wave"></i>
              <span>Наличными или картой курьеру</span>
            </div>
            <div class="payment-option" onclick="selectPayment('online', this)">
              <i class="fas fa-credit-card"></i>
              <span>Онлайн картой</span>
            </div>
          </div>
          <input type="hidden" id="paymentMethod" value="cash">

          <!-- Форма карты (только для online) -->
          <div class="card-form" id="card-form-block">
            <div style="margin-top:20px;padding:16px;background:var(--bg);border-radius:10px;">
              <div class="form-group">
                <label class="form-label">Номер карты</label>
                <input class="form-control" type="text" id="cardNumber" placeholder="0000 0000 0000 0000" maxlength="19"
                  oninput="formatCard(this)">
              </div>
              <div class="card-row">
                <div class="form-group">
                  <label class="form-label">Срок действия</label>
                  <input class="form-control" type="text" id="cardExpiry" placeholder="ММ/ГГ" maxlength="5"
                    oninput="formatExpiry(this)">
                </div>
                <div class="form-group">
                  <label class="form-label">CVV</label>
                  <input class="form-control" type="text" id="cardCvv" placeholder="***" maxlength="3" inputmode="numeric" oninput="this.value=this.value.replace(/\D/g,'')">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Имя на карте</label>
                <input class="form-control" type="text" id="cardName" placeholder="IVAN IVANOV">
              </div>
            </div>
          </div>
        </div>

        <div id="checkout-error" style="display:none;" class="auth-error"></div>

        <button class="btn btn-primary btn-lg btn-block" id="submit-order-btn" onclick="submitOrder(this)">
          <i class="fas fa-check"></i> Подтвердить заказ
        </button>
      </div>

      <!-- Сводка заказа -->
      <div>
        <div class="cart-summary" style="position:sticky;top:120px;">
          <h3>Ваш заказ</h3>
          <div id="order-items">
            <% let total = 0; items.forEach(item => { total += Number(item.price) * item.quantity; %>
            <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);">
              <img src="<%= item.image_url || '/images/placeholder.jpg' %>" alt="" style="width:50px;height:50px;object-fit:contain;border-radius:6px;background:#fafafa;padding:4px;" onerror="this.onerror=null;this.src='/images/placeholder.jpg'">
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:600;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= item.name %></div>
                <div style="font-size:12px;color:var(--text-muted);">× <%= item.quantity %></div>
              </div>
              <div style="font-size:14px;font-weight:700;white-space:nowrap;"><%= (Number(item.price) * item.quantity).toLocaleString('ru-RU') %> ₽</div>
            </div>
            <% }) %>
          </div>
          <div class="summary-row" style="margin-top:10px;">
            <span>Товары</span>
            <span><%= total.toLocaleString('ru-RU') %> ₽</span>
          </div>
          <div class="summary-row">
            <span>Доставка</span>
            <span style="color:var(--primary);font-weight:600;">Бесплатно</span>
          </div>
          <div class="summary-row total">
            <span>Итого</span>
            <span><%= total.toLocaleString('ru-RU') %> ₽</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── Карта доставки (только курьер) ─────────────────────────
var _map = null, _courierMarker = null, _delivMode = 'pickup', _detectedStreet = '';

function initDeliveryMap() {
  if (_map) { _map.invalidateSize(); return; }
  _map = L.map('delivery-map', { attributionControl: false }).setView([52.555, 103.888], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom:19 }).addTo(_map);

  _map.on('click', function(e) {
    var lat = e.latlng.lat, lng = e.latlng.lng;
    if (_courierMarker) _courierMarker.setLatLng([lat, lng]);
    else _courierMarker = L.marker([lat, lng]).addTo(_map);

    var streetEl = document.getElementById('street-text');
    var streetBlock = document.getElementById('street-display');
    var hint = document.getElementById('map-hint');
    streetEl.textContent = 'Определение адреса...';
    streetBlock.style.display = 'block';
    hint.style.display = 'none';

    fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat='+lat+'&lon='+lng, {
      headers:{ 'Accept-Language':'ru' }
    }).then(function(r){ return r.json(); })
      .then(function(d){
        var a = d.address || {};
        _detectedStreet = [a.road, a.suburb, a.city || a.town || a.village].filter(Boolean).join(', ')
                       || d.display_name || (lat.toFixed(4)+', '+lng.toFixed(4));
        streetEl.textContent = _detectedStreet;
      })
      .catch(function(){
        _detectedStreet = lat.toFixed(4)+', '+lng.toFixed(4);
        streetEl.textContent = _detectedStreet;
      });
  });
}

function setDelivMode(mode) {
  _delivMode = mode;
  var isPick = mode === 'pickup';
  document.getElementById('dopt-pickup').classList.toggle('selected', isPick);
  document.getElementById('dopt-courier').classList.toggle('selected', !isPick);
  document.getElementById('pickup-block').style.display  = isPick ? 'block' : 'none';
  document.getElementById('courier-block').style.display = isPick ? 'none'  : 'block';
  if (!isPick) {
    setTimeout(function(){
      initDeliveryMap();
      _map.invalidateSize();
    }, 50);
  }
}

document.addEventListener('DOMContentLoaded', function() {
  <% var pd = (typeof profile !== 'undefined') ? profile : {}; %>
  <% if (pd.delivery_mode === 'courier') { %>
  setDelivMode('courier');
  setTimeout(function() {
    <% if (pd.delivery_street) { %>
    _detectedStreet = '<%- (pd.delivery_street || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>';
    document.getElementById('street-text').textContent = _detectedStreet;
    document.getElementById('street-display').style.display = 'block';
    document.getElementById('map-hint').style.display = 'none';
    <% } %>
    <% if (pd.delivery_house)  { %> document.getElementById('addr-house').value  = '<%= pd.delivery_house %>'; <% } %>
    <% if (pd.delivery_apt)    { %> document.getElementById('addr-apt').value    = '<%= pd.delivery_apt %>'; <% } %>
    <% if (pd.delivery_floor)  { %> document.getElementById('addr-floor').value  = '<%= pd.delivery_floor %>'; <% } %>
  }, 100);
  <% } %>
});
// ───────────────────────────────────────────────────────────
</script>

<script>
// ── Маска телефона ──────────────────────────────────────────
(function() {
  var PH_PREFIX = '+7 (';
  var PHONE_FULL_RE = /^\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}$/;
  var phInp = document.getElementById('phone');
  if (!phInp) return;

  function getPhDigits(val) {
    var d = (val || '').replace(/\D/g, '');
    if (d[0] === '7' || d[0] === '8') d = d.slice(1);
    return d.slice(0, 10);
  }
  function buildMask(digits) {
    if (!digits.length) return PH_PREFIX;
    var out = '+7 (' + digits.slice(0, 3);
    if (digits.length > 3) out += ') ' + digits.slice(3, 6);
    if (digits.length > 6) out += '-'  + digits.slice(6, 8);
    if (digits.length > 8) out += '-'  + digits.slice(8, 10);
    return out;
  }
  function digitsBefore(str, pos) {
    var n = 0;
    for (var i = 2; i < pos && i < str.length; i++) {
      if (/\d/.test(str[i])) n++;
    }
    return n;
  }
  function posAfterNth(str, n) {
    if (n <= 0) return PH_PREFIX.length;
    var cnt = 0;
    for (var i = 2; i < str.length; i++) {
      if (/\d/.test(str[i]) && ++cnt === n) return i + 1;
    }
    return str.length;
  }
  function phCommit(digits, curDigitIdx) {
    phInp.value = digits.length ? buildMask(digits) : PH_PREFIX;
    var p = posAfterNth(phInp.value, curDigitIdx);
    phInp.setSelectionRange(p, p);
  }

  phInp.addEventListener('focus', function() {
    if (!this.value) this.value = PH_PREFIX;
  });
  phInp.addEventListener('blur', function() {
    if (!this.value || this.value === PH_PREFIX) this.value = '';
  });
  phInp.addEventListener('beforeinput', function(e) {
    e.preventDefault();
    var fmt = this.value || PH_PREFIX;
    var s0 = this.selectionStart, s1 = this.selectionEnd;
    var digits = getPhDigits(fmt);
    var di0 = digitsBefore(fmt, s0), di1 = digitsBefore(fmt, s1);
    var nd, ni;
    switch (e.inputType) {
      case 'deleteContentBackward': case 'deleteWordBackward':
        if (s0 === s1) { nd = digits.slice(0, Math.max(0, di0 - 1)) + digits.slice(di0); ni = Math.max(0, di0 - 1); }
        else           { nd = digits.slice(0, di0) + digits.slice(di1); ni = di0; }
        break;
      case 'deleteContentForward': case 'deleteWordForward':
        if (s0 === s1) { nd = digits.slice(0, di0) + digits.slice(di0 + 1); ni = di0; }
        else           { nd = digits.slice(0, di0) + digits.slice(di1); ni = di0; }
        break;
      default:
        var raw = e.data || (e.dataTransfer && e.dataTransfer.getData('text/plain')) || '';
        var typed = raw.replace(/\D/g, '');
        if (!typed) return;
        if (typed.length > 1 && (typed[0] === '7' || typed[0] === '8')) typed = typed.slice(1);
        typed = typed.slice(0, 10 - (digits.length - (di1 - di0)));
        nd = (digits.slice(0, di0) + typed + digits.slice(di1)).slice(0, 10);
        ni = di0 + typed.length;
    }
    phCommit(nd, ni);
  });
})();
// ───────────────────────────────────────────────────────────

let selectedPayment = 'cash';
document.getElementById('card-form-block').style.display = 'none';

function selectPayment(method, el) {
  selectedPayment = method;
  document.getElementById('paymentMethod').value = method;
  el.closest('.payment-methods').querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('card-form-block').style.display = method === 'online' ? 'block' : 'none';
}

function formatCard(input) {
  let v = input.value.replace(/\D/g, '').substring(0, 16);
  input.value = v.replace(/(.{4})/g, '$1 ').trim();
}

function formatExpiry(input) {
  let v = input.value.replace(/\D/g, '');
  if (v.length >= 2) v = v.substring(0, 2) + '/' + v.substring(2, 4);
  input.value = v;
}

async function submitOrder(btn) {
  if (!btn) btn = document.getElementById('submit-order-btn');
  const customerName = document.getElementById('customerName').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const errEl = document.getElementById('checkout-error');

  let address;
  if (_delivMode === 'pickup') {
    address = 'Самовывоз: г. Ангарск, ул. Примерная, 123';
  } else {
    var house = (document.getElementById('addr-house')?.value || '').trim();
    var apt   = (document.getElementById('addr-apt')?.value || '').trim();
    var floor = (document.getElementById('addr-floor')?.value || '').trim();
    if (!_detectedStreet || !house) {
      errEl.textContent = 'Укажите адрес на карте и номер дома';
      errEl.style.display = 'block';
      return;
    }
    address = _detectedStreet + ', д. ' + house
      + (apt   ? ', кв. ' + apt   : '')
      + (floor ? ', эт. ' + floor : '');
  }

  if (!customerName || !phone) {
    errEl.textContent = 'Пожалуйста, заполните все обязательные поля';
    errEl.style.display = 'block';
    return;
  }

  if (selectedPayment === 'online') {
    const cardNum = document.getElementById('cardNumber').value.replace(/\s/g, '');
    const expiry = document.getElementById('cardExpiry').value;
    const cvv = document.getElementById('cardCvv').value;
    if (cardNum.length < 16 || !expiry.includes('/') || cvv.length < 3) {
      errEl.textContent = 'Пожалуйста, заполните данные карты корректно';
      errEl.style.display = 'block';
      return;
    }
  }

  errEl.style.display = 'none';
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Обработка...';

  await new Promise(r => setTimeout(r, selectedPayment === 'online' ? 1500 : 300));

  const res = await fetch('/api/checkout', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify({
      customerName, phone, address, paymentMethod: selectedPayment,
      deliveryMode: _delivMode,
      deliveryStreet: _detectedStreet || null,
      deliveryHouse:  (document.getElementById('addr-house')?.value  || '').trim() || null,
      deliveryApt:    (document.getElementById('addr-apt')?.value    || '').trim() || null,
      deliveryFloor:  (document.getElementById('addr-floor')?.value  || '').trim() || null,
    })
  });

  const data = await res.json();
  if (res.ok && data.success) {
    window.location.href = `/order/success?orderId=${data.orderId}`;
  } else {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-check"></i> Подтвердить заказ';
    errEl.textContent = data.message || 'Ошибка оформления заказа';
    errEl.style.display = 'block';
  }
}
</script>
