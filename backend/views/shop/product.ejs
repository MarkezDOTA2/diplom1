<%- include('../partials/header', {
  title: product.name,
  breadcrumbs: [
    { label: product.category, url: '/category/' + slug },
    { label: product.name, url: '/product/' + product.id }
  ],
  slug
}) %>

<main>
  <div class="container">

    <!-- Детальная страница товара -->
    <div class="product-detail">

      <!-- Галерея -->
      <div class="product-gallery">
        <img id="main-img" class="product-main-img"
          src="<%= product.image_url || '/images/placeholder.jpg' %>"
          alt="<%= product.name %>"
          onerror="this.onerror=null;this.src='/images/placeholder.jpg'">

        <% if (images.length > 0) { %>
        <div class="product-thumbs">
          <div class="product-thumb active" onclick="setMainImg('<%= product.image_url || '/images/placeholder.jpg' %>', this)">
            <img src="<%= product.image_url || '/images/placeholder.jpg' %>" alt="" onerror="this.onerror=null;this.src='/images/placeholder.jpg'">
          </div>
          <% images.forEach(img => { %>
          <div class="product-thumb" onclick="setMainImg('<%= img.image_url %>', this)">
            <img src="<%= img.image_url %>" alt="" onerror="this.onerror=null;this.src='/images/placeholder.jpg'">
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Информация -->
      <div class="product-info-panel">
        <% if (product.brand) { %>
        <div class="product-brand-badge"><%= product.brand %></div>
        <% } %>
        <h1 class="product-title"><%= product.name %></h1>
        <div class="product-price">
          <%= Number(product.price).toLocaleString('ru-RU') %> ₽
          <% if (product.old_price) { %><span class="product-card-old-price" style="font-size:18px;margin-left:8px;"><%= Number(product.old_price).toLocaleString('ru-RU') %> ₽</span><% } %>
        </div>

        <div class="product-actions">
          <button class="btn btn-primary btn-lg" id="add-cart-btn" onclick="addToCart(<%= product.id %>, this)">
            <i class="fas fa-shopping-cart"></i> В корзину
          </button>
          <button class="btn btn-outline" id="fav-btn" onclick="toggleFav(<%= product.id %>, this)" title="В избранное">
            <i class="fas fa-heart"></i>
          </button>
        </div>

        <div style="background:var(--bg);border-radius:10px;padding:16px;margin-bottom:20px;">
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;font-size:14px;">
              <i class="fas fa-truck" style="color:var(--primary)"></i>
              <span>Доставка 1–3 дня</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;font-size:14px;">
              <i class="fas fa-shield-alt" style="color:var(--primary)"></i>
              <span>Гарантия 1 год</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;font-size:14px;">
              <i class="fas fa-undo" style="color:var(--primary)"></i>
              <span>Возврат 14 дней</span>
            </div>
          </div>
        </div>


      </div>
    </div>

    <!-- Табы: Описание / Характеристики -->
    <div class="product-tabs">
      <div class="tabs-nav">
        <button class="tab-btn active" id="tab-desc" onclick="showTab('desc')">Описание</button>
        <% if (specs.length > 0) { %>
        <button class="tab-btn" id="tab-specs" onclick="showTab('specs')">Характеристики (<%= specs.length %>)</button>
        <% } %>
      </div>

      <div class="tab-content active" id="content-desc">
        <% if (product.description) { %>
        <div style="font-size:15px;line-height:1.8;color:var(--text-muted);max-width:860px;">
          <%= product.description %>
        </div>
        <% } else { %>
        <p style="color:var(--text-light);">Описание не добавлено.</p>
        <% } %>
      </div>

      <% if (specs.length > 0) { %>
      <div class="tab-content" id="content-specs">
        <table class="specs-table" style="max-width:700px;">
          <% specs.forEach(s => { %>
          <tr>
            <td><%= s.spec_name %></td>
            <td><strong><%= s.spec_value %></strong></td>
          </tr>
          <% }) %>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Похожие товары -->
    <% if (related.length > 0) { %>
    <section style="margin-top:48px;margin-bottom:48px;">
      <h2 class="section-title">Похожие товары</h2>
      <div class="products-grid">
        <% related.forEach(p => { %>
        <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
      </div>
    </section>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>

<script>
function setMainImg(src, thumb) {
  document.getElementById('main-img').src = src;
  document.querySelectorAll('.product-thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

function showTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.getElementById('content-' + tab).classList.add('active');
}

async function addToCart(productId, btn) {
  const res = await fetch('/api/cart/add', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
    body: JSON.stringify({ productId, quantity: 1 })
  });
  if (res.status === 401) { showToast('Войдите в аккаунт, чтобы добавить товар в корзину. <a href="/login">Войти</a>', 'warning', 5000); return; }
  if (res.ok) {
    btn.style.background = '#27ae60';
    btn.innerHTML = '<i class="fas fa-check"></i> В корзине';
    showToast('Товар добавлен в корзину', 'success');
    updateCartCount();
    setTimeout(() => { btn.style.background=''; btn.innerHTML='<i class="fas fa-shopping-cart"></i> В корзину'; }, 2000);
  }
}

async function toggleFav(productId, btn) {
  const isFav = btn.classList.contains('active');
  const res = await fetch(isFav ? '/favorites/remove' : '/favorites/add', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
    body: JSON.stringify({ productId })
  });
  if (res.status === 401) { showToast('Войдите в аккаунт, чтобы добавить в избранное. <a href="/login">Войти</a>', 'warning', 5000); return; }
  if (res.ok) {
    btn.classList.toggle('active');
    showToast(isFav ? 'Удалено из избранного' : 'Добавлено в избранное', isFav ? 'info' : 'success');
  }
}

document.addEventListener('DOMContentLoaded', async () => {
  try {
    const res = await fetch('/api/favorites', { credentials: 'include' });
    if (!res.ok) return;
    const { data } = await res.json();
    const btn = document.getElementById('fav-btn');
    if (btn && data.includes(<%= product.id %>)) btn.classList.add('active');
    document.querySelectorAll('.product-card-fav').forEach(btn => {
      if (data.includes(parseInt(btn.dataset.id))) btn.classList.add('active');
    });
  } catch {}
});
</script>
