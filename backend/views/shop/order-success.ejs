<%- include('../partials/header', { title: 'Заказ оформлен' }) %>

<main>

  <!-- Hero -->
  <div class="success-hero">
    <div class="success-check-wrap">
      <svg class="success-checkmark" viewBox="0 0 52 52">
        <circle class="success-circle" cx="26" cy="26" r="23"/>
        <path class="success-check-path" d="M14 27 l8 8 l16-16"/>
      </svg>
    </div>
    <h1>Заказ успешно оформлен!</h1>
    <p>Заказ&nbsp;<strong>#<%= order.id %></strong> принят в обработку</p>
  </div>

  <!-- Card -->
  <div class="success-wrap">
    <div class="success-card">

      <!-- Шапка -->
      <div class="success-card-header">
        <div>
          <div class="success-order-label">Номер заказа</div>
          <div class="success-order-num">#<%= order.id %></div>
        </div>
        <div style="text-align:right;">
          <div class="success-order-label">Статус</div>
          <span class="badge badge-<%= order.status %>">
            <%= ({new:'Новый',paid:'Оплачен',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'})[order.status] || order.status %>
          </span>
        </div>
      </div>

      <!-- Адрес -->
      <div class="success-section">
        <div class="success-section-title"><i class="fas fa-map-marker-alt"></i> Адрес доставки</div>
        <div style="font-size:14px;color:var(--text);">
          <% if (order.address && order.address.startsWith('Самовывоз')) { %>
            <i class="fas fa-store" style="color:var(--primary);margin-right:6px;"></i><%= order.address %>
          <% } else { %>
            <i class="fas fa-motorcycle" style="color:var(--primary);margin-right:6px;"></i><%= order.address %>
          <% } %>
        </div>
      </div>

      <!-- Товары -->
      <div class="success-section">
        <div class="success-section-title"><i class="fas fa-box"></i> Состав заказа</div>
        <% items.forEach(function(item) { %>
        <div class="success-product-row">
          <img class="success-product-img"
            src="<%= item.image_url || '/images/placeholder.jpg' %>" alt="<%= item.name %>"
            onerror="this.onerror=null;this.src='/images/placeholder.jpg'">
          <div class="success-product-name"><%= item.name %></div>
          <div class="success-product-qty">× <%= item.quantity %></div>
          <div class="success-product-price"><%= (Number(item.price) * item.quantity).toLocaleString('ru-RU') %> ₽</div>
        </div>
        <% }) %>
      </div>

      <!-- Оплата -->
      <div class="success-section" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
        <div>
          <div class="success-section-title"><i class="fas fa-credit-card"></i> Способ оплаты</div>
          <% if (order.payment_method === 'online') { %>
          <span class="success-payment-chip">
            <i class="fas fa-credit-card"></i> Онлайн картой — оплачено
          </span>
          <% } else { %>
          <span class="success-payment-chip">
            <i class="fas fa-money-bill-wave"></i> Наличными или картой курьеру
          </span>
          <% } %>
        </div>
        <% if (order.payment_method !== 'online') { %>
        <div style="font-size:12px;color:var(--text-muted);max-width:200px;text-align:right;line-height:1.4;">
          Менеджер свяжется с вами для подтверждения
        </div>
        <% } %>
      </div>

      <!-- Итого -->
      <div class="success-total-row">
        <span>Итого</span>
        <span><%= Number(order.total_price).toLocaleString('ru-RU') %> ₽</span>
      </div>

    </div>

    <!-- Кнопки -->
    <div class="success-actions">
      <a href="/profile" class="btn btn-primary">
        <i class="fas fa-receipt"></i> Мои заказы
      </a>
      <a href="/" class="btn btn-secondary">
        <i class="fas fa-shopping-bag"></i> Продолжить покупки
      </a>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
