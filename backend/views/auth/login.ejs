<%- include('../partials/header', { title: 'Вход в аккаунт' }) %>

<main>
  <div class="auth-page">
    <div class="auth-card">

      <div class="auth-card-header">
        <div class="auth-logo-icon">
          <i class="fas fa-sign-in-alt"></i>
        </div>
        <h2>Вход в аккаунт</h2>
        <p class="auth-subtitle">Войдите, чтобы управлять заказами и избранным</p>
      </div>

      <div class="auth-card-body">
        <% if (error) { %>
        <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <form method="POST" action="/login" id="loginForm" novalidate>
          <div class="form-group">
            <label class="form-label">Имя пользователя</label>
            <div class="auth-input-wrap">
              <i class="fas fa-user auth-field-icon"></i>
              <input class="form-control" type="text" name="username" id="loginUsername"
                placeholder="Введите имя пользователя" autofocus>
            </div>
            <div class="field-error" id="err-username">
              <i class="fas fa-exclamation-circle"></i>
              <span>Пожалуйста, введите имя пользователя</span>
            </div>
          </div>

          <div class="form-group" style="margin-bottom:24px;">
            <label class="form-label">Пароль</label>
            <div class="auth-input-wrap">
              <i class="fas fa-lock auth-field-icon"></i>
              <input class="form-control" type="password" name="password" id="loginPassword"
                placeholder="Введите пароль" style="padding-right:42px;">
              <button type="button" class="auth-toggle-pw" onclick="togglePw('loginPassword', this)" tabindex="-1">
                <i class="fas fa-eye"></i>
              </button>
            </div>
            <div class="field-error" id="err-password">
              <i class="fas fa-exclamation-circle"></i>
              <span>Пожалуйста, введите пароль</span>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg">
            <i class="fas fa-sign-in-alt"></i> Войти
          </button>
        </form>

        <div class="auth-divider">или</div>

        <div class="auth-alt">
          Нет аккаунта? <a href="/register">Зарегистрироваться</a>
        </div>
      </div>

    </div>
  </div>
</main>

<script>
function togglePw(id, btn) {
  var inp = document.getElementById(id);
  var icon = btn.querySelector('i');
  if (inp.type === 'password') {
    inp.type = 'text';
    icon.className = 'fas fa-eye-slash';
  } else {
    inp.type = 'password';
    icon.className = 'fas fa-eye';
  }
}

(function() {
  function showErr(input, errEl) {
    input.classList.add('is-invalid');
    errEl.classList.add('visible');
  }
  function clearErr(input, errEl) {
    input.classList.remove('is-invalid');
    errEl.classList.remove('visible');
  }

  var uInp = document.getElementById('loginUsername');
  var pInp = document.getElementById('loginPassword');
  var uErr = document.getElementById('err-username');
  var pErr = document.getElementById('err-password');

  uInp.addEventListener('input', function() { if (uInp.value.trim()) clearErr(uInp, uErr); });
  pInp.addEventListener('input', function() { if (pInp.value)        clearErr(pInp, pErr); });

  document.getElementById('loginForm').addEventListener('submit', function(e) {
    var ok = true;
    if (!uInp.value.trim()) { showErr(uInp, uErr); ok = false; }
    else clearErr(uInp, uErr);
    if (!pInp.value) { showErr(pInp, pErr); ok = false; }
    else clearErr(pInp, pErr);
    if (!ok) e.preventDefault();
  });
})();
</script>

<%- include('../partials/footer') %>
