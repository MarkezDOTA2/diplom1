<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | Админ' : 'Панель администратора' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="admin-layout">

  <!-- Сайдбар -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-logo">
      <i class="fas fa-cube" style="color:#48D1CC;margin-right:8px;"></i>
      Store<span style="color:#48D1CC;">Chicco</span> Admin
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage === 'orders' ? 'active' : '' %>">
        <i class="fas fa-shopping-bag"></i> Заказы
      </a>
      <a href="/admin/products" class="<%= typeof activePage !== 'undefined' && activePage === 'products' ? 'active' : '' %>">
        <i class="fas fa-boxes"></i> Товары
      </a>
      <a href="/admin/categories" class="<%= typeof activePage !== 'undefined' && activePage === 'categories' ? 'active' : '' %>">
        <i class="fas fa-tags"></i> Категории
      </a>
      <a href="/" style="margin-top:auto;">
        <i class="fas fa-external-link-alt"></i> На сайт
      </a>
      <a href="/admin/logout" onclick="event.preventDefault();document.getElementById('admin-logout-f').submit();" style="color:#ff7675;">
        <i class="fas fa-sign-out-alt"></i> Выйти
      </a>
      <form id="admin-logout-f" action="/admin/logout" method="POST" style="display:none;"></form>
    </nav>
  </aside>

  <!-- Контент -->
  <div class="admin-main">
    <div class="admin-topbar">
      <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h1>
      <div style="font-size:14px;color:var(--text-muted);">
        <i class="fas fa-user-shield" style="color:var(--primary)"></i>
        Администратор: <strong><%= admin.username %></strong>
      </div>
    </div>
    <div class="admin-content">
